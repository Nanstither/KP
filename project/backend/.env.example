# Unisender Go — форма обратной связи
# Получить ключ: https://go.unisender.ru/ → Учётная запись → Безопасность → API-ключ
UNISENDER_GO_API_KEY=
UNISENDER_GO_API_URL=https://goapi.unisender.ru/ru/transactional/api/v1/

# Куда приходят сообщения с формы «Напишите нам»
CONTACT_TO_EMAIL=

# Отправитель (должен быть подтверждён в Unisender Go)
CONTACT_FROM_EMAIL=
CONTACT_FROM_NAME="Tech Lab"

# SSL для Windows/локальной разработки (cacert.pem лежит в storage/certs/)
# UNISENDER_GO_CA_BUNDLE=
# Если всё равно ошибка cURL 60 — временно для local:
# UNISENDER_GO_VERIFY_SSL=false
