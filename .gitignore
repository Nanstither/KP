```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
dist/
build/
target/

# Dependencies
node_modules/
vendor/
*.lock

# Logs and temp files
*.log
*.tmp
*.swp

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Coverage
coverage/
htmlcov/
.coverage

# Python specific
*.pyc
__pycache__/
*.pyo
*.pyd
.Python
*.so
.Python
*.egg-info/
.eggs/
.mypy_cache/
.pytest_cache/
.tox/
.hypothesis/

# Node.js specific
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# PHP specific
*.php~
.htaccess

# Build systems
.gradle/
build/
target/
dist/
```