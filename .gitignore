```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
dist/
build/
target/

# Dependencies
node_modules/
vendor/
*.lock

# Logs and temp files
*.log
*.tmp
*.swp

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/
*.swp
*.swo

# OS specific
.DS_Store
Thumbs.db

# Coverage
coverage/
htmlcov/
.coverage

# Python specific
*.pyc
__pycache__/
*.pyo
*.pyd
.Python
*.so
.Python
*.egg-info/
.eggs/

# PHP specific
*.phar
vendor/composer/
composer.lock

# Node specific
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
build/
dist/
out/
public/build/
static/css/*.css.map
static/js/*.js.map

# Testing
.phpunit.result.cache
.nyc_output/
coverage/

# IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
nbproject/

# System
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
```