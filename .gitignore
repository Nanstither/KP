```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
dist/
build/

# Dependencies
node_modules/
vendor/
composer.lock

# Logs and temp files
*.log
*.tmp
*.swp

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# OS generated files
.DS_Store
Thumbs.db

# PHP specific
*.php~
.php_cs.cache

# Frontend build artifacts
*.min.js
*.min.css
coverage/
.nyc_output/
```